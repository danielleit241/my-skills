{
  "schemaVersion": 2,
  "profile": {
    "codingLevel": -1,
    "language": {
      "conversation": "vi",
      "artifacts": "vi"
    }
  },
  "workspace": {
    "root": "plans",
    "dateFormat": "YYMMDD"
  },
  "retention": {
    "compactDays": 3,
    "memoryDays": 30
  },
  "hooks": {
    "caveman": {
      "enabled": true,
      "threshold": {
        "orange": 50,
        "red": 100
      }
    },
    "simplifyGate": {
      "enabled": false,
      "threshold": {
        "totalLoc": 400,
        "fileCount": 8,
        "singleFileLoc": 200
      }
    }
  },
  "safety": {
    "privacyBlock": {
      "enabled": true,
      "allowList": []
    }
  }
}
