{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_init.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/subagent_init.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/prompt_context.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|Glob|Grep|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/tool_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pre_compact.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_end.py",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_end.py",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  },
  "ignorePatterns": [
    "**/bin/**",
    "**/obj/**",
    "**/.vs/**",
    "**/.git/**",
    "**/Migrations/**",
    "**/TestResults/**",
    "**/coverage/**",
    "**/session-data/**",
    "**/*.suo",
    "**/*.user",
    "**/*.lock.json",
    "**/node_modules/**"
  ],
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "true"
  }
}
