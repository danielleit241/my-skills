{
  "name": "@danielle241/forge",
  "version": "2.1.7",
  "description": "Versioned CLI for installing and migrating AI agent toolkits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielleit241/forge.git"
  },
  "homepage": "https://github.com/danielleit241/forge#readme",
  "bugs": {
    "url": "https://github.com/danielleit241/forge/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "forge": "dist/cli.js"
  },
  "files": [
    "dist",
    ".claude/agents/*.md",
    ".claude/coding-levels",
    ".claude/commands",
    ".claude/hooks/*.py",
    ".claude/hooks/lib/*.py",
    ".claude/settings.json",
    ".claude/skills",
    "toolkit.manifest.json",
    "CHANGELOG.md",
    "CLAUDE.md",
    ".mcp.json",
    ".ck.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/engine.test.js dist/tests/onboarding.test.js dist/tests/project.test.js dist/tests/transaction.test.js",
    "validate:skills": "node scripts/validate-skills.mjs",
    "validate:toolkit": "npm run build && node dist/cli.js validate --source .",
    "version:check": "node scripts/check-release-version.mjs",
    "release:check": "npm run check && npm run validate:skills && npm test && npm run validate:toolkit && npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run validate:skills && npm test && npm run validate:toolkit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.0",
    "diff": "^8.0.2",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.30",
    "@types/semver": "^7.7.0",
    "typescript": "^5.8.3"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
